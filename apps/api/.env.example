NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Local Postgres from `docker compose up -d db`. Leave unset to boot without a DB.
DATABASE_URL=postgres://subflow:subflow@localhost:5432/subflow

# Optional
SENTRY_DSN=

# base64 AES-256-GCM key (subF-7). In prod this comes from Secrets Manager — never commit a real key.
TOKEN_ENCRYPTION_KEY=

# monobank (subF-8/9). Point MONO_BASE_URL at a local mock for verification runs;
# MONO_LEASE_SECONDS lowers the 1req/60s pacing ONLY for such runs.
MONO_BASE_URL=https://api.monobank.ua
MONO_LEASE_SECONDS=60
